#!/usr/bin/env bash
# ghxd wrapper — lazily installs the ghxd daemon binary, then delegates to it.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
DATA_DIR="${CLAUDE_PLUGIN_DATA:-$HOME/.ghx-plugin}"
BIN_DIR="$DATA_DIR/bin"

# Use the installed binary if it exists
if [ -x "$BIN_DIR/ghxd" ]; then
  exec "$BIN_DIR/ghxd" "$@"
fi

# Attempt installation
if "$PLUGIN_ROOT/scripts/install.sh" "$BIN_DIR" >&2; then
  if [ -x "$BIN_DIR/ghxd" ]; then
    exec "$BIN_DIR/ghxd" "$@"
  fi
fi

echo "ghxd plugin: could not install ghxd" >&2
exit 1
